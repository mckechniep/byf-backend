# ==================== SERVER CONFIGURATION ====================

# Server port (default: 5000)
PORT=5000

# Node environment (development | production | test)
NODE_ENV=development

# ==================== DATABASE CONFIGURATION ====================

# MongoDB connection string
# Local: mongodb://localhost:27017/lapointe
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/lapointe?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/lapointe

# ==================== JWT AUTHENTICATION ====================

# Secret key for signing JWT tokens (CHANGE THIS IN PRODUCTION!)
# Generate a secure key with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT token expiration time (examples: "1h", "7d", "30m", "24h")
JWT_EXPIRES_IN=24h

# ==================== CORS CONFIGURATION ====================

# Allowed frontend origins (comma-separated for multiple origins)
# Example: http://localhost:3000,http://localhost:5173,https://yourapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== OPTIONAL SERVICES ====================

# Cloudinary (for image uploads - to be implemented)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Stripe (for payments - to be implemented)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Email Service (for notifications - to be implemented)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ==================== SECURITY ====================

# Rate limiting (optional - defaults are set in code)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# AUTH_RATE_LIMIT_MAX=5

# ==================== LOGGING ====================

# Log level (error | warn | info | debug)
# LOG_LEVEL=info
